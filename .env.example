# ═══════════════════════════════════════════════════════════
# AssesIN — Environment Variables
# Salin file ini menjadi .env.local untuk development lokal
# Di Vercel: tambahkan di Settings → Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────
# Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════
# SUPABASE EDGE FUNCTIONS — set di Supabase Dashboard:
# Settings → Edge Functions → Secrets
# ═══════════════════════════════════════════════════════════

# ── Midtrans ─────────────────────────────────────────────
# Midtrans Dashboard → Settings → Access Keys
# JANGAN gunakan Client Key di sini — hanya Server Key
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx   # sandbox
# MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxx    # production

MIDTRANS_IS_PRODUCTION=false   # ganti ke true saat go-live

# ── Supabase (untuk Edge Functions) ──────────────────────
# Otomatis tersedia di Edge Functions, tidak perlu diisi manual:
# SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY

# ── Frontend URL (untuk Midtrans callback) ────────────────
FRONTEND_URL=https://assesin.com
